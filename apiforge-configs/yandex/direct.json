{
  "base_url": "https://api.direct.yandex.com/json/v5",
  "sandbox_url": "https://api-sandbox.direct.yandex.com/json/v5",
  "auth": {
    "token": "${YANDEX_DIRECT_TOKEN}"
  },
  "default_headers": {
    "Accept-Language": "ru",
    "Client-Login": "${YANDEX_DIRECT_CLIENT_LOGIN}",
    "processingMode": "auto",
    "returnMoneyInMicros": "false",
    "skipReportHeader": "true",
    "skipColumnHeader": "true",
    "skipReportSummary": "true"
  },
  "resources": {
    "reports": {
      "path": "/reports",
      "method": "POST",
      "description": "Сервис Reports - получение статистики по аккаунту Директа",
      "parameters": {
        "SelectionCriteria": {
          "type": "object",
          "required": true,
          "description": "Критерии отбора данных для отчета",
          "properties": {
            "DateFrom": {
              "type": "string",
              "required": false,
              "description": "Начальная дата отчетного периода (YYYY-MM-DD). Обязательно при DateRangeType=CUSTOM_DATE"
            },
            "DateTo": {
              "type": "string",
              "required": false,
              "description": "Конечная дата отчетного периода (YYYY-MM-DD). Обязательно при DateRangeType=CUSTOM_DATE"
            },
            "Filter": {
              "type": "array",
              "required": false,
              "description": "Фильтры данных"
            }
          }
        },
        "FieldNames": {
          "type": "array",
          "required": true,
          "description": "Имена полей (столбцов), которые будут присутствовать в отчете"
        },
        "ReportName": {
          "type": "string",
          "required": true,
          "description": "Название отчета. Должно быть уникальным для пользователя в режиме офлайн"
        },
        "ReportType": {
          "type": "string",
          "required": true,
          "description": "Тип отчета",
          "enum": [
            "ACCOUNT_PERFORMANCE_REPORT",
            "CAMPAIGN_PERFORMANCE_REPORT",
            "ADGROUP_PERFORMANCE_REPORT",
            "AD_PERFORMANCE_REPORT",
            "CRITERIA_PERFORMANCE_REPORT",
            "CUSTOM_REPORT",
            "REACH_AND_FREQUENCY_PERFORMANCE_REPORT",
            "SEARCH_QUERY_PERFORMANCE_REPORT"
          ]
        },
        "DateRangeType": {
          "type": "string",
          "required": true,
          "description": "Период, за который формируется отчет",
          "enum": [
            "TODAY",
            "YESTERDAY",
            "LAST_3_DAYS",
            "LAST_5_DAYS",
            "LAST_7_DAYS",
            "LAST_14_DAYS",
            "LAST_30_DAYS",
            "LAST_90_DAYS",
            "LAST_365_DAYS",
            "THIS_WEEK_MON_TODAY",
            "THIS_WEEK_SUN_TODAY",
            "LAST_WEEK",
            "LAST_BUSINESS_WEEK",
            "LAST_WEEK_SUN_SAT",
            "THIS_MONTH",
            "LAST_MONTH",
            "ALL_TIME",
            "CUSTOM_DATE",
            "AUTO"
          ]
        },
        "Format": {
          "type": "string",
          "required": true,
          "description": "Формат отчета. В настоящее время поддерживается только TSV",
          "enum": ["TSV"]
        },
        "IncludeVAT": {
          "type": "string",
          "required": true,
          "description": "Включать ли НДС в денежные суммы в отчете",
          "enum": ["YES", "NO"]
        },
        "IncludeDiscount": {
          "type": "string",
          "required": false,
          "description": "Учитывать ли скидку для денежных сумм в отчете. Утратил актуальность с 1 сентября 2015 года",
          "enum": ["YES", "NO"]
        },
        "Goals": {
          "type": "array",
          "required": false,
          "description": "Идентификаторы целей Яндекс Метрики (не более 10 элементов)"
        },
        "AttributionModels": {
          "type": "array",
          "required": false,
          "description": "Модели атрибуции для расчета данных по целям Яндекс Метрики",
          "enum": ["FCCD", "LC", "LSCCD", "AUTO"]
        },
        "Page": {
          "type": "object",
          "required": false,
          "description": "Ограничение на количество строк в отчете (максимум 1 000 000)",
          "properties": {
            "Limit": {
              "type": "integer",
              "required": true,
              "description": "Максимальное количество строк в отчете"
            },
            "Offset": {
              "type": "integer",
              "required": false,
              "description": "Количество строк, которое должно быть пропущено при выборке"
            }
          }
        },
        "OrderBy": {
          "type": "array",
          "required": false,
          "description": "Сортировка строк в отчете",
          "items": {
            "type": "object",
            "properties": {
              "Field": {
                "type": "string",
                "required": true,
                "description": "Имя поля для сортировки"
              },
              "SortOrder": {
                "type": "string",
                "required": false,
                "description": "Направление сортировки",
                "enum": ["ASCENDING", "DESCENDING"]
              }
            }
          }
        }
      }
    },
