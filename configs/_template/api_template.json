{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApiForge API Configuration",
  "description": "Configuration file for ApiForge API client",
  "type": "object",
  "required": ["base_url", "resources"],
  "properties": {
    "base_url": {
      "type": "string",
      "format": "uri",
      "description": "Base URL for the API"
    },
    "auth": {
      "type": "object",
      "description": "Authentication configuration",
      "properties": {
        "token": {"type": "string"},
        "api_key": {"type": "string"},
        "username": {"type": "string"},
        "password": {"type": "string"}
      }
    },
    "default_headers": {
      "type": "object",
      "description": "Default headers for all requests",
      "additionalProperties": {"type": "string"}
    },
    "resources": {
      "type": "object",
      "description": "API resources/endpoints",
      "additionalProperties": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Endpoint path (supports {param} placeholders)"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "default": "GET"
          },
          "description": {
            "type": "string"
          },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": {"type": "string"},
                "required": {"type": "boolean"},
                "description": {"type": "string"},
                "default": {}
              }
            }
          },
          "headers": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          }
        }
      }
    }
  }
}
